## t/test_neo4j.stk — assertion tests for the stryke `Neo4j` package.
##
## Connection-free asserts always run. The graph asserts need a live Neo4j via
## $NEO4J_URL (+ $NEO4J_USER / $NEO4J_PASS); they short-circuit when none is set
## so CI without a database stays green. A throwaway local instance works (e.g.
## the neo4j Docker image).

use Neo4j

# ── permission-free: cdylib reachable ───────────────────────────────
assert_ok Neo4j::version(), "Neo4j::version returns truthy (cdylib loaded)"
assert_eq Neo4j::redact_url("bolt://u:p\@h:7687"), "bolt://u:***\@h:7687", "redact pure helper"

# ── live Neo4j (opt-in) ─────────────────────────────────────────────
var %conn
if (defined $ENV{NEO4J_URL}) {
    $conn{uri}      = $ENV{NEO4J_URL}
    $conn{user}     = $ENV{NEO4J_USER} // "neo4j"
    $conn{password} = $ENV{NEO4J_PASS} if defined $ENV{NEO4J_PASS}

    val $up = eval { Neo4j::ping(%conn) }
    if ($up) {
        val $tag = "stryke_test_$$"

        # 1. scalar
        assert_eq Neo4j::scalar("RETURN 1 + 1 AS n", %conn), 2, "scalar arithmetic"

        # 2. write with params
        Neo4j::run(
            "CREATE (p:$tag {id: \$id, name: \$name})",
            params => { id => 1, name => "Ada" },
            %conn,
        )

        # 3. query back (row keyed by RETURN alias)
        val @rows = Neo4j::query("MATCH (p:$tag) WHERE p.id = \$id RETURN p.name AS name", params => { id => 1 }, %conn)
        assert_eq scalar(@rows), 1, "query returns one row"
        assert_eq $rows[0]{name}, "Ada", "node property round-trips"

        # 4. count via scalar
        Neo4j::run("CREATE (p:$tag {id: 2, name: 'Alan'})", %conn)
        assert_eq Neo4j::scalar("MATCH (p:$tag) RETURN count(p) AS n", %conn), 2, "count is 2"

        # 5. label shows up in introspection
        val @labels = Neo4j::labels(%conn)
        assert_ok scalar(@labels) > 0, "labels() returns rows"

        # 6. point lookups + existence by (label, key, value)
        val $node = Neo4j::get_node($tag, "id", 1, %conn)
        assert_eq $node->{name}, "Ada", "get_node returns the matched node"
        assert_eq Neo4j::exists_node($tag, "id", 1, %conn), \1, "exists_node true for present node"
        assert_eq Neo4j::exists_node($tag, "id", 999, %conn), \0, "exists_node false for absent node"

        # 7. relationship + degree (Alan KNOWS Ada)
        Neo4j::create_rel(
            from_label => $tag, from_key => "id", from_value => 2,
            to_label   => $tag, to_key   => "id", to_value   => 1,
            type       => "KNOWS",
            %conn,
        )
        assert_ok Neo4j::relationship_count(type => "KNOWS", %conn) >= 1, "relationship_count counts KNOWS"
        assert_eq Neo4j::degree($tag, "id", 2, direction => "out", type => "KNOWS", %conn), 1, "degree out KNOWS is 1"
        assert_eq Neo4j::degree($tag, "id", 1, direction => "in", type => "KNOWS", %conn), 1, "degree in KNOWS is 1"

        # 8. query_column plucks a named column
        val @names = Neo4j::query_column("MATCH (p:$tag) RETURN p.name AS nm ORDER BY nm", "nm", %conn)
        assert_eq scalar(@names), 2, "query_column returns two values"
        assert_eq $names[0], "Ada", "query_column first value"

        # 9. count_property_values groups by a property
        val @dist = Neo4j::count_property_values($tag, "name", %conn)
        assert_eq scalar(@dist), 2, "count_property_values returns two groups"

        # 10. point delete
        assert_eq Neo4j::delete_node($tag, "id", 1, %conn), 1, "delete_node removes one node"
        assert_eq Neo4j::exists_node($tag, "id", 1, %conn), \0, "node gone after delete_node"

        # cleanup
        Neo4j::run("MATCH (p:$tag) DETACH DELETE p", %conn)
    }
}

test_run
